{
  "name": "app/log-service",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "symfony/framework-bundle": "^7.0",
    "symfony/runtime": "^7.0",
    "symfony/console": "^7.0",
    "symfony/http-foundation": "^7.0",
    "symfony/routing": "^7.0",
    "symfony/serializer": "^7.0",
    "symfony/validator": "^7.0",
    "symfony/messenger": "^7.0",
    "symfony/amqp-messenger": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "symfony/test-pack": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
